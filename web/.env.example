# PostHog (EU) — product analytics. Unset = track() logs to console in dev, no-ops in prod.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Upstash Redis (REST) — quotes cache. Unset = in-memory Map fallback (local dev needs no setup).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
